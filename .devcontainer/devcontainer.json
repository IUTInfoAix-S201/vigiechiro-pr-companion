{
    "name": "SAÉ 2.01 Development Environment",
    // Image pré-buildée publiée par .github/workflows/devcontainer-image.yml.
    // Les features (java/SDKMAN, desktop-lite, github-cli, common-utils) y sont
    // déjà bakées : le démarrage d'un Codespace ne fait que pull cette image,
    // sans aucun appel SDKMAN/noVNC -> fini les échecs sur HTTP 504 SDKMAN.
    // Recette de l'image : .devcontainer/image/devcontainer.json.
    "image": "ghcr.io/iutinfoaix-s201/vigiechiro-pr-companion-devcontainer:latest",
    "forwardPorts": [6080, 5901],
    // onCreateCommand : pré-télécharge les dépendances (dependency:go-offline)
    // pour que le LSP Java et le premier build ne soient pas bloqués par le
    // réseau. bash -lc pour charger SDKMAN. On NE compile PAS au démarrage
    // (pas de test-compile) : un target/ compilé ici peut devenir périmé après
    // une régénération de branche ou un pull et faire mentir « Nothing to
    // compile » (module-info.class obsolète -> erreurs JPMS au javafx:run).
    // jdt.ls indexe de son côté, donc les CodeLens "Run | Debug" apparaissent
    // quand même, juste un peu plus tard. Réflexe en cas de doute : ./mvnw clean.
    "onCreateCommand": "bash -lc './mvnw -q dependency:go-offline || true' && gh repo set-default \"$(git remote get-url origin | sed 's|.*github.com[:/]||' | sed 's|\\.git$||')\" 2>/dev/null || true",
    "customizations": {
        "vscode": {
            "settings": {
                "java.jdt.ls.java.home": "/usr/local/sdkman/candidates/java/current",
                "terminal.integrated.profiles.linux": {
                    "zsh": { "path": "zsh" }
                },
                "terminal.integrated.defaultProfile.linux": "zsh",
                "redhat.telemetry.enabled": false
            },
            "extensions": [
                "redhat.java",
                "redhat.vscode-xml",
                "vscjava.vscode-java-debug",
                "vscjava.vscode-java-test",
                "vscjava.vscode-maven",
                "vscjava.vscode-java-dependency",
                "eamodio.gitlens",
                "GitHub.copilot-chat"
            ]
        }
    },
    "remoteUser": "vscode"
}

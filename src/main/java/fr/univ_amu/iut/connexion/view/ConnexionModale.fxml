<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!--
  Modale « Connexion VigieChiro » (#727), ouverte depuis la carte d'accueil du même nom dans un Stage
  modal applicatif. On colle le token obtenu sur le site (marque-page), l'app vérifie l'identité via
  GET /moi et l'affiche ; « Se déconnecter » efface la connexion locale. Câblée au ConnexionViewModel
  par ConnexionModaleController.
-->
<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:id="racine"
      fx:controller="fr.univ_amu.iut.connexion.view.ConnexionModaleController"
      stylesheets="@../../commun/view/palette.css, @../../commun/view/design.css"
      prefWidth="540.0"
      spacing="12.0">

  <Label text="Connexion VigieChiro" styleClass="titre-page"/>
  <Label text="Collez le token obtenu sur le site VigieChiro (via le marque-page « Token VigieChiro »). Il relie l'application à votre compte pour le dépôt et la synchronisation."
         styleClass="section-sous" wrapText="true"/>

  <Label fx:id="labelIdentite" styleClass="bandeau-valeur"/>

  <VBox spacing="4.0">
    <Label text="Token" styleClass="bandeau-label"/>
    <TextField fx:id="champToken" promptText="collez votre token ici"/>
  </VBox>

  <Label fx:id="labelMessage" styleClass="message-erreur" wrapText="true"/>

  <HBox alignment="CENTER_RIGHT" spacing="8.0">
    <Button fx:id="boutonDeconnecter" text="Se déconnecter"
            styleClass="action-secondaire" onAction="#deconnecter"/>
    <Region HBox.hgrow="ALWAYS"/>
    <Button text="Fermer" styleClass="action-secondaire" onAction="#fermer"/>
    <Button fx:id="boutonConnecter" text="Se connecter"
            styleClass="action-primaire" onAction="#connecter"/>
  </HBox>
</VBox>
